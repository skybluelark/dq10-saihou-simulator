{
  "name": "dq10-saihou-simulator",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:site": "npm run build && node scripts/build-site.mjs",
    "preview": "vite preview",
    "test": "vitest run --exclude \"tests/stats/**\"",
    "test:quick": "vitest run --reporter=dot --exclude \"tests/stats/**\"",
    "test:stats": "vitest run tests/stats",
    "lint": "eslint src",
    "recipes:import": "vite-node scripts/recipes-import.ts",
    "recipes:export": "vite-node scripts/recipes-export.ts",
    "solver:bench": "vite-node scripts/solver-bench.ts",
    "solver:agreement": "vite-node scripts/solver-agreement.ts",
    "solver:dp": "vite-node scripts/solver-dp-dump.ts",
    "replay:trace": "vite-node scripts/replay-trace.ts",
    "selfplay:replay": "vite-node scripts/selfplay-replay.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.9.0",
    "eslint-plugin-import": "^2.29.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.1",
    "vitest": "^2.0.5"
  }
}
